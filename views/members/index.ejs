
        <%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold text-dark text-uppercase">Quản lý Hội viên</h3>
    <a href="/members/add" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg"></i> Thêm mới</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr class="text-secondary">
                    <th class="ps-4">ID</th>
                    <th>Họ và Tên</th>
                    <th>Liên hệ</th>
                    <th>Giới tính</th>
                    <th>Ngày tham gia</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <% members.forEach(member => { %>
                <tr style="vertical-align: middle;">
                    <td class="ps-4 text-muted">#<%= member.id %></td>
                    <td><span class="fw-semibold"><%= member.fullname %></span></td>
                    <td><i class="bi bi-telephone text-muted me-1"></i> <%= member.phone %></td>
                    <td>
                        <span class="badge <%= member.gender === 'Nam' ? 'bg-primary-subtle text-primary' : 'bg-danger-subtle text-danger' %> p-2">
                            <%= member.gender %>
                        </span>
                    </td>
                    <td class="text-muted"><%= new Date(member.join_date).toLocaleDateString('vi-VN') %></td>
                    <td class="text-end pe-4">
                        <button class="btn btn-outline-warning btn-sm border-0"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-outline-danger btn-sm border-0"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
